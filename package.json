    "build:types": "tsc --build",
    "build:build": "tsup",
    "build:test": "vitest --run",
    "watch": "npm-run-all --parallel watch:check watch:build watch:test",
    "watch:check": "tsc --watch --preserveWatchOutput",
    "watch:build": "tsup --watch",
    "watch:test": "vitest",
    "hq": "./run-task.sh hq",
    "electron": "electron bin/electron.cjs electron",
    "clean": "rm -rf build bin"
  },
